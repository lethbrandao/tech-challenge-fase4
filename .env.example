# ─── Azure Cognitive Services ─────────────────────────────────────────────────
# Speech to Text
AZURE_SPEECH_KEY=your_speech_key_here
AZURE_SPEECH_REGION=eastus

# Text Analytics
AZURE_TEXT_ANALYTICS_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_TEXT_ANALYTICS_KEY=your_text_analytics_key_here

# ─── Configurações do projeto ─────────────────────────────────────────────────
# Caminhos de dados (ajuste conforme necessário)
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
REPORTS_PATH=reports

# Nível de log (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Limiar de anomalia (0.0 a 1.0) — abaixo desse score gera alerta
ANOMALY_THRESHOLD=0.15

# ─── Configurações de vídeo ───────────────────────────────────────────────────
# Número de frames a processar por segundo do vídeo (reduz custo computacional)
VIDEO_SAMPLE_FPS=2
YOLO_MODEL_PATH=weights/yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

# ─── Configurações de áudio ───────────────────────────────────────────────────
AUDIO_LANGUAGE=pt-BR
